      {
        "id": "hidden-train-shard",
        "purpose": "hidden-train-replay",
        "hash": "example-hidden-train-shard-sha256"
      },
      {
        "id": "hidden-validation-shard",
        "purpose": "hidden-validation-loss",
        "hash": "example-hidden-validation-shard-sha256"
      }
    ]
  },
  "training_protocol": {
    "model_family": "fixed tiny decoder-only language model",
    "tokenizer": "fixed by verifier lockfile",
    "optimizer": "fixed by verifier lockfile",
    "schedule": "fixed by verifier lockfile",
    "token_budget": "fixed by verifier track",
    "downstream_mini_eval": "fixed by verifier lockfile"
  },
  "seed_policy": {
    "verified_min_seeds": 1,
    "promoted_min_seeds": 3,
    "replicated_min_seeds": 5
  },
  "replay_outputs": {
    "replay_result_json": "path/to/replay-result.json",
    "result_card_markdown": "path/to/result-card.md",
    "runner_log": "path/to/runner-log.jsonl",
